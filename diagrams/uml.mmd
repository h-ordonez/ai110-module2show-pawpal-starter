classDiagram
    class Owner {
        +String name
        +List petList
        +addPet(pet)
        +removePet(pet)
        +getTasks() List
    }

    class Pet {
        +String name
        +String species
        +int age
        +List taskList
    }

    class Task {
        +String description
        +Time time
        +Frequency frequency
        +bool completed
        +markCompleted()
    }

    class Frequency {
        <<enumeration>>
        DAILY
        WEEKLY
        MONTHLY
    }

    class Scheduler {
        +Owner owner
        +scheduleTask(pet, task)
        +removeTask(pet, task)
        +getTasksByPet(pet) List
        +getAllTasks() List
    }

    Owner "1" --> "many" Pet : has
    Pet "1" --> "many" Task : has
    Task "many" --> "1" Frequency : recurs
    Scheduler "1" --> "1" Owner : manages
    Scheduler ..> Task : organizes
