classDiagram
    class Owner {
        +String name
        +List petList
        +Scheduler scheduler
        +addPet(pet)
        +removePet(pet)
        +getTasks() List
    }

    class Pet {
        +String name
        +String species
        +int age
        +getNeeds() String
    }

    class Task {
        +String title
        +String description
        +bool completed
        +Date dueDate
        +Pet pet
        +isDone() bool
    }

    class Scheduler {
        +Owner owner
        +Map schedule
        +scheduleTask(task, date)
        +removeTask(task)
        +getUpcomingTasks() List
        +getTasksByPet(pet) List
    }

    Owner "1" --> "many" Pet : has
    Owner "1" --> "1" Scheduler : scheduled by
    Scheduler "1" --> "1" Owner : manages
    Scheduler "1" --> "many" Task : owns
    Task "many" --> "1" Pet : for
